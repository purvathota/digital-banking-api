              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"category\": \"GROCERIES\",\n  \"monthlyLimit\": 500.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/budgets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
